# ==============================================
# 1. DATABASE CONNECTIONS (Docker Local)
# ==============================================

# PostgreSQL (Core Game Data & Questions)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/logicforge?schema=public"

# MongoDB (Authentication & User Sessions) – used by apps/web and packages/db
# Format: mongodb://USER:PASSWORD@HOST:PORT/DB_NAME?authSource=admin
MONGO_URL="mongodb://admin:password@localhost:27017/logicforge_auth?authSource=admin"

# Redis (Caching & Real-time Pub/Sub)
REDIS_URL="redis://localhost:6379"

# ==============================================
# 2. NEXT AUTHENTICATION (Auth.js)
# ==============================================

# The URL of your web application
NEXTAUTH_URL="http://localhost:3000"

# Secret key for encrypting sessions (Generate one with: openssl rand -base64 32)
NEXTAUTH_SECRET="change_this_to_a_secure_random_string"

# ==============================================
# 3. OAUTH PROVIDERS
# ==============================================

# GitHub OAuth (Get these from GitHub Developer Settings)
GITHUB_ID=""
GITHUB_SECRET=""

# Google OAuth (Get these from Google Cloud Console)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ==============================================
# 4. SERVICE CONFIGURATION
# ==============================================

# Environment (development, test, production)
NODE_ENV="development"

# Port Configuration (Optional overrides)
PORT_WEB=3000
PORT_GAME_API=3001
PORT_QUESTION_ENGINE=3002
PORT_ANTI_CHEAT=3003