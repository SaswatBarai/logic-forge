{
  "name": "@logicforge/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc",
    "db:generate": "prisma generate --schema=./prisma/schema.prisma && prisma generate --schema=./prisma/mongo.prisma",
    "db:push": "prisma db push --schema=./prisma/schema.prisma && prisma db push --schema=./prisma/mongo.prisma",
    "studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.10.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@logicforge/tsconfig": "workspace:*",
    "@types/node": "^20.11.24",
    "prisma": "^5.10.2",
    "typescript": "^5.3.3"
  }
}