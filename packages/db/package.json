{
  "name": "@logicforge/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "db:generate": "prisma generate --schema=./prisma/schema.prisma && prisma generate --schema=./prisma/mongo.prisma",
    "db:push": "prisma db push --schema=./prisma/schema.prisma && prisma db push --schema=./prisma/mongo.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.10.2"
  },
  "devDependencies": {
    "@logicforge/tsconfig": "workspace:*",
    "prisma": "^5.10.2",
    "typescript": "^5.3.3",
    "@types/node": "^20.11.24"
  }
}