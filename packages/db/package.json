{
  "name": "@logicforge/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc",
    "db:generate": "prisma generate --config ./prisma.config.ts && prisma generate --config ./prisma.mongo.config.ts",
    "db:push": "prisma db push --config ./prisma.config.ts && prisma db push --config ./prisma.mongo.config.ts",
    "studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@logicforge/tsconfig": "workspace:*",
    "@types/node": "^20.11.24",
    "dotenv": "^16.3.1",
    "prisma": "^6.19.0",
    "typescript": "^5.3.3"
  }
}